<script>
const SUPA_URL = 'https://ppehttbtrlavnrytoweu.supabase.co';
const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBwZWh0dGJ0cmxhdm5yeXRvd2V1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU0Nzk0MzMsImV4cCI6MjA5MTA1NTQzM30.FXYL9UGnW3zhvwapbyYfD5aCoS8R-iNguS3_6Ba_mbY';

let db;
try {
  db = supabase.createClient(SUPA_URL, SUPA_KEY, { auth: { persistSession: true, storageKey: 'spark_auth' } });
} catch(e) { console.warn('Supabase init failed — demo mode', e); db = null; }

let ME = null;
let PROFILE = { username:'@user123', spk_balance:4520 };

function switchAuth(tab) {
  document.getElementById('fmSI').style.display  = tab==='signin' ? '' : 'none';
  document.getElementById('fmSU').style.display  = tab==='signup' ? '' : 'none';
  document.getElementById('tabSI').classList.toggle('on', tab==='signin');
  document.getElementById('tabSU').classList.toggle('on', tab==='signup');
  setAuthErr('');
}
function setAuthErr(m){ document.getElementById('authErr').textContent = m; }
function setBtnState(id, dis){ const b=document.getElementById(id); if(b) b.disabled=dis; }

async function doSignIn() {
  const email = document.getElementById('siEmail').value.trim();
  const pass  = document.getElementById('siPass').value;
  if (!email||!pass) return;
  setBtnState('btnSI', true); setAuthErr('');

  if (!db) { PROFILE.username='@demo'; enterApp(); return; }

  const { data, error } = await db.auth.signInWithPassword({ email, password:pass });
  if (error) { setAuthErr(error.message); setBtnState('btnSI',false); return; }
  ME = data.user;
  await fetchProfile();
  enterApp();
}

async function doSignUp() {
  const nick  = document.getElementById('suNick').value.trim().replace(/^@/,'');
  const email = document.getElementById('suEmail').value.trim();
  const pass  = document.getElementById('suPass').value;
  const pass2 = document.getElementById('suPass2').value;
  if (!nick||!email||!pass||!pass2) return;
  if (pass !== pass2) { setAuthErr(LANG==='ru'?'Пароли не совпадают':'Passwords do not match'); return; }
  setBtnState('btnSU', true); setAuthErr('');

  if (!db) { PROFILE.username='@'+nick; enterApp(); return; }

  const { data, error } = await db.auth.signUp({ email, password:pass });
  if (error) { setAuthErr(error.message); setBtnState('btnSU',false); return; }

  ME = data.user;
  if (ME) await db.from('profiles').upsert({ id: ME.id, username: '@'+nick, spk_balance: 4520 });
  PROFILE.username = '@' + nick;

  if (data.user?.email_confirmed_at || data.session) {
    enterApp();
  } else {
    showVerify(email, nick);
    setBtnState('btnSU', false);
  }
}

async function fetchProfile() {
  if (!db||!ME) return;
  const { data } = await db.from('profiles').select('*').eq('id',ME.id).single();
  if (data) { PROFILE.username = data.username||'@user'; PROFILE.spk_balance = data.spk_balance||4520; }
}

async function doLogout() {
  if (db) await db.auth.signOut();
  location.reload();
