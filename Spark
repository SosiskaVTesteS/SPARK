function hideVerify() { document.getElementById('verify-modal').classList.remove('show'); }

async function checkEmailVerified() {
  const btn = document.getElementById('vmConfirmBtn');
  btn.disabled = true; btn.textContent = 'Проверяем…';
  document.getElementById('vmErr').textContent = '';

  if (!db) { hideVerify(); enterApp(); return; }

  try {
    const { data, error } = await db.auth.refreshSession();
    if (error) {
      const { data: ud } = await db.auth.getUser();
      if (ud?.user?.email_confirmed_at) { ME = ud.user; await fetchProfile(); hideVerify(); enterApp(); }
      else document.getElementById('vmErr').textContent = 'Почта ещё не подтверждена. Проверьте папку «Спам».';
    } else if (data?.user?.email_confirmed_at) {
      ME = data.user; await fetchProfile(); hideVerify(); enterApp();
    } else {
      document.getElementById('vmErr').textContent = 'Почта ещё не подтверждена. Проверьте папку «Спам».';
    }
  } catch (e) { document.getElementById('vmErr').textContent = 'Ошибка проверки.'; }

  btn.disabled = false; btn.textContent = T('vmBtn');
}

async function resendVerification() {
  if (!db || !PENDING_EMAIL) return;
  document.getElementById('vmErr').textContent = '';
  const { error } = await db.auth.resend({ type:'signup', email: PENDING_EMAIL });
  document.getElementById('vmErr').textContent = error ? 'Ошибка: ' + error.message : '✉️ Письмо отправлено повторно!';
}

