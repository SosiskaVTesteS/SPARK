// ════════════════════════════════════════
// ANIMATED GRAPHS
// ════════════════════════════════════════
function buildGraphPath(history) {
  const safe = history.reduce((acc, v, i) => { acc.push(i === 0 ? v : Math.max(v, acc[i-1])); return acc; }, []);
  const range = safe[safe.length - 1] - safe[0] || 1;
  const pts = safe.map((v, i) => ({ x: GRAPH_PAD + (i / (safe.length - 1 || 1)) * (GRAPH_W - GRAPH_PAD*2), y: GRAPH_PAD + (GRAPH_H - GRAPH_PAD*2) - ((v - safe[0]) / range) * (GRAPH_H - GRAPH_PAD*2) }));
  const d = pts.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
  return { d, lastPt: pts[pts.length - 1] };
}

function drawInvestmentGraph(svgEl, history) {
  if (!svgEl || history.length < 2) return;
  const id = 'g' + Math.random().toString(36).slice(2);
  const { d, lastPt } = buildGraphPath(history);
  svgEl.innerHTML = `
    <defs><linearGradient id="igf-${id}" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#e8c55a" stop-opacity="0.22"/><stop offset="100%" stop-color="#e8c55a" stop-opacity="0"/></linearGradient></defs>
    <path d="${d} L${GRAPH_W - GRAPH_PAD},${GRAPH_H} L${GRAPH_PAD},${GRAPH_H} Z" fill="url(#igf-${id})" class="ig-fill"/>
    <path d="${d}" class="ig-line" id="line-${id}"/>
    <circle cx="${lastPt.x.toFixed(1)}" cy="${lastPt.y.toFixed(1)}" r="3.5" class="ig-dot" id="dot-${id}"/>
  `;
  requestAnimationFrame(() => {
    const line = document.getElementById(`line-${id}`);
    const dot = document.getElementById(`dot-${id}`);
    if(!line) return;
    const len = line.getTotalLength();
    line.style.setProperty('--ig-len', `${len}`); line.style.setProperty('--ig-dur', `1.6s`);
    line.style.strokeDasharray = len; line.style.strokeDashoffset = len;
    requestAnimationFrame(() => { line.classList.add('animated'); setTimeout(() => dot?.classList.add('show'), 1200); });
  });
}

function animateAllGraphs(container) {
  const svgs = container.querySelectorAll('svg.igsvg[data-history]');
  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(e => { if (e.isIntersecting) { drawInvestmentGraph(e.target, JSON.parse(e.target.dataset.history)); obs.unobserve(e.target); } });
  }, { threshold: 0.2 });
  svgs.forEach(svg => observer.observe(svg));
}

